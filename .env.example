# =====================================================
# Terraform RAG - Environment Configuration
# =====================================================
# Copy to .env and fill in your values:
#   cp .env.example .env

# -- PostgreSQL ----------------------------------------
POSTGRES_USER=terraform_rag
POSTGRES_PASSWORD=changeme
POSTGRES_DB=terraform_rag
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# -- Redis ---------------------------------------------
REDIS_URL=redis://redis:6379/0

# -- LLM ----------------------------------------------
# API key (Anthropic, OpenRouter, or placeholder for Ollama)
ANTHROPIC_API_KEY=sk-...

# Option A: Anthropic API (direct)
LLM_MODEL=claude-sonnet-4-6
LLM_BASE_URL=

# Option B: OpenRouter
# LLM_MODEL=anthropic/claude-sonnet-4-6
# LLM_BASE_URL=https://openrouter.ai/api/v1
# ANTHROPIC_API_KEY=sk-or-...

# Option C: Ollama (local, free)
# LLM_MODEL=qwen2.5-coder:32b
# LLM_BASE_URL=http://ollama:11434/v1
# ANTHROPIC_API_KEY=ollama

# Option D: AWS Bedrock (uses IAM auth - no ANTHROPIC_API_KEY needed)
# LLM_MODEL=us.anthropic.claude-sonnet-4-6-20250514-v1:0
# AWS_BEDROCK_REGION=us-east-1
# AWS_BEDROCK_PROFILE=           # optional: AWS profile for local dev
# AWS_BEDROCK_ROLE_ARN=          # optional: cross-account role to assume

# Parallel LLM calls during indexing (default 1 = sequential).
# Increase for local inference servers (e.g. 4 for LMStudio).
LLM_CONCURRENT_PROMPTS=1

# Extended thinking budget for Anthropic models (0 = disabled)
LLM_THINKING_BUDGET=8192

# Max retries on transient API errors (429, 500, 529)
LLM_MAX_RETRIES=3

# -- LLM for descriptions (indexing) ------------------
# Separate (cheaper) model for generating module descriptions.
# Leave empty to fall back to the main LLM settings above.
DESCRIPTION_LLM_MODEL=
DESCRIPTION_LLM_BASE_URL=
DESCRIPTION_LLM_API_KEY=
DESCRIPTION_LLM_TEMPERATURE=0.2

# -- Embeddings ----------------------------------------
# Provider: "local" = sentence-transformers on CPU (no API key needed)
#           "bedrock" = Amazon Bedrock API (uses IAM auth, no PyTorch needed)
EMBEDDING_PROVIDER=local

# Local provider settings
EMBEDDING_MODEL=Snowflake/snowflake-arctic-embed-m-v2.0
EMBEDDING_DIM=768

# Bedrock provider settings (used when EMBEDDING_PROVIDER=bedrock)
# EMBEDDING_PROVIDER=bedrock
# EMBEDDING_BEDROCK_MODEL_ID=amazon.titan-embed-text-v2:0
# EMBEDDING_BEDROCK_REGION=us-east-1
# EMBEDDING_DIM=1024

# -- Agent ---------------------------------------------
# Iterative tool-use agent loop for all query types.
# Works with both Anthropic and OpenAI-compatible backends.
AGENT_COMPOSE_ENABLED=false
AGENT_MAX_TURNS=15
AGENT_MODEL=
AGENT_THINKING_BUDGET=4096

# -- Webhooks ------------------------------------------
GITHUB_WEBHOOK_SECRET=
GITLAB_WEBHOOK_TOKEN=

# -- Auth ----------------------------------------------
# "disabled" - no authentication, all endpoints public
# "local"    - email/password login with JWT tokens
# "sso"      - ALB-terminated OIDC (AWS Identity Center)
AUTH_MODE=disabled
JWT_SECRET=change-me-in-production
FRONTEND_URL=http://localhost:3000

# SSO mode (only used when AUTH_MODE=sso)
SSO_ADMIN_GROUPS=terraform-rag-admins
SSO_USER_GROUPS=terraform-rag-users
SSO_REGION=eu-west-1

# Local mode - seed initial admin user on first startup
ADMIN_INITIAL_EMAIL=
ADMIN_INITIAL_PASSWORD=

# -- Audit logging -------------------------------------
AUDIT_LOG_ENABLED=true
# Set to false to redact prompt/response text in audit logs
AUDIT_LOG_LLM_PROMPTS=true

# -- Misc ----------------------------------------------
MCP_SEED_API_KEY=              # pre-generated trag_* key for MCP access (seeded on startup)
DEBUG=false
REPO_CACHE_DIR=/tmp/repo_cache
