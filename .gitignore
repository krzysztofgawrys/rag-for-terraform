# =============================================================================
# Secrets & local config — NEVER commit
# =============================================================================
.env
.env.*
!.env.example
*.pem
*.key
worker_deploy_key
worker_deploy_key.pub
secrets/
.secrets/

# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Virtual environments
.venv/
venv/
env/
ENV/
.python-version

# Build artifacts
build/
dist/
*.egg-info/
*.egg
.eggs/
pip-wheel-metadata/

# Test / coverage / type-checker caches
.pytest_cache/
.tox/
.nox/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
.hypothesis/
.mypy_cache/
.pyre/
.pytype/
.ruff_cache/

# Jupyter
.ipynb_checkpoints/

# =============================================================================
# Node / frontend
# =============================================================================
node_modules/
frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/stats.html

# Lockfile policy: keep package-lock.json committed.
# npm/yarn debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# =============================================================================
# Editors / IDEs
# =============================================================================
.vscode/
!.vscode/settings.json.example
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

