# Claude Code / AI tooling
# =============================================================================
.mcp.json
.claude/settings.local.json
.claude/cache/
.claude/logs/
.claude/transcripts/
# Keep .claude/settings.json (shared) and skills/ committed.

# =============================================================================
# Docker / runtime data
# =============================================================================
# Bind-mounted volumes from docker-compose (if any are written into the repo)
postgres_data/
redis_data/
.docker/

# =============================================================================
# Logs & temp
# =============================================================================
*.log
logs/
tmp/
.tmp/
*.tmp
*.bak
*.orig

# =============================================================================
# Project-specific
# =============================================================================
# Local clones used for ad-hoc analysis (not part of the codebase)
/tmp-analysis/
*.tf-analysis/

# Embedding model cache (sentence-transformers downloads to ~/.cache by default,
# but if anyone overrides HF_HOME inside the repo, ignore it)
.hf_cache/
.sentence_transformers/
/models/

# Local SSH known_hosts seeded into the worker
known_hosts.local
