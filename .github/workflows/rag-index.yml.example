name: Terraform RAG - Auto Reindex

on:
  push:
    branches: [main, master]
    paths:
      - "**.tf"
      - "**.tfvars"
      - "tags.txt"
      - ".tags"

jobs:
  reindex:
    runs-on: ubuntu-latest
    steps:
      - name: Trigger RAG reindexing
        run: |
          response=$(curl -s -w "\n%{http_code}" -X POST \
            "${{ secrets.RAG_BACKEND_URL }}/index/" \
            -H "Content-Type: application/json" \
            -H "Authorization: Bearer ${{ secrets.RAG_API_KEY }}" \
            -d '{
              "repo_url": "git@github.com:${{ github.repository }}.git",
              "branch": "${{ github.ref_name }}",
              "commit_sha": "${{ github.sha }}",
              "triggered_by": "github_actions"
            }')
          http_code=$(echo "$response" | tail -1)
          body=$(echo "$response" | head -n -1)
          echo "Status: $http_code"
          echo "Response: $body"
          if [ "$http_code" -ne 202 ]; then
            echo "::error::Reindex trigger failed with HTTP $http_code"
            exit 1
          fi

# Required GitHub repository secrets:
#   RAG_BACKEND_URL  - e.g. https://terraform-rag.your-domain.com
#   RAG_API_KEY      - trag_* API key with admin role (from Terraform output: ci_api_key)
